# Скопируйте в .env в корне репозитория (файл .env в git не коммитится):
#   cp scripts/ingestion/.env.example .env
# Затем из корня:
#   set -a && source .env && set +a
#   python3 scripts/ingestion/smoke_fetch.py all
# Ретроспектива (уже были продажи / EZ PIN / перевод в Точку) — один и тот же
# календарный интервал, например:
#   TOCHKA_STATEMENT_DATE_FROM / TOCHKA_STATEMENT_DATE_TO
#   YANDEX_NETTING_DATE_FROM / YANDEX_NETTING_DATE_TO
#   (в POST orders диапазон ≤ 30 дней — гонять окнами)
#   python3 scripts/ingestion/smoke_fetch.py ledger

# --- Точка (OAuth client_credentials или готовый токен) ---
# TOCHKA_ACCESS_TOKEN=   # если уже есть JWT — TOCHKA_CLIENT_* не нужны
TOCHKA_CLIENT_ID=
TOCHKA_CLIENT_SECRET=
# Пробелы между scope. Если 400/403 — сверьтесь с кабинетом приложения и
# https://developers.tochka.com/docs/tochka-api/algoritm-raboty-po-oauth-2-0
# (иногда в примерах встречаются короткие имена: accounts balances statements).
TOCHKA_SCOPE=ReadAccountsBasic ReadAccountsDetail ReadStatements ReadBalances
# TOCHKA_CUSTOMER_CODE=   # если требуется заголовок Customer-Code
# TOCHKA_ACCOUNT_ID=      # id счёта из ответа списка счетов — для режима ledger / выписка
# TOCHKA_STATEMENT_DATE_FROM=2026-04-01
# TOCHKA_STATEMENT_DATE_TO=2026-04-16
# TOCHKA_INIT_STATEMENT_JSON={"Data":{"Statement":{...}}}  # если стандартное тело Init не подходит

# --- Яндекс Маркет Partner API ---
YANDEX_MARKET_API_KEY=
YANDEX_BUSINESS_ID=
# YANDEX_CAMPAIGN_IDS=149014578   # через запятую — фильтр заказов и отчёта united-netting
# YANDEX_NETTING_DATE_FROM=2026-04-01
# YANDEX_NETTING_DATE_TO=2026-04-16
# YANDEX_NETTING_FORMAT=JSON     # FILE | CSV | JSON
# YANDEX_SKIP_UNITED_NETTING=1   # не дергать отчёт по платежам (лимиты API)
# EZPAYPIN_FETCH_CATALOG=1       # в режиме ledger дополнительно GET /catalogs/

# --- EZ PIN / EZPayPin ---
EZPAYPIN_CLIENT_ID=
EZPAYPIN_SECRET_KEY=
